-- 1. Crie o usuário do Duin em Authentication > Users.
-- 2. Copie o UUID do usuário e substitua abaixo.
-- 3. Execute este comando no SQL Editor.

update public.profiles
set
    full_name = 'Duin',
    role = 'admin',
    active = true
where id = 'COLE_AQUI_O_UUID_DO_USUARIO';

-- Confirme:
select id, full_name, email, role, active
from public.profiles
where id = 'COLE_AQUI_O_UUID_DO_USUARIO';
